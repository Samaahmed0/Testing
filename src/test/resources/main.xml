<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="Exercise3 - Smoke then Regression" verbose="1">

    <!-- Run SMOKE first -->
    <test name="Smoke Tests">
        <groups>
            <run>
                <include name="Smoke"/>
            </run>
        </groups>
        <classes>
            <class name="com.guru99.TestBankingGroups"/>
        </classes>
    </test>

    <!-- Then REGRESSION -->
    <test name="Regression Tests">
        <groups>
            <run>
                <include name="Regression"/>
            </run>
        </groups>
        <classes>
            <class name="com.guru99.TestBankingGroups"/>
        </classes>
    </test>

</suite>